# ============================================================
# EduRAG 环境配置文件
# 使用方法: 复制此文件为 .env，再填入实际值
#   cp .env.example .env
# ============================================================

# ── PostgreSQL（Docker Compose 默认值，无需修改）────────────
DATABASE_URL=postgresql+asyncpg://eduraq:eduraq@localhost:5432/eduraq
DATABASE_URL_SYNC=postgresql://eduraq:eduraq@localhost:5432/eduraq

# ── ChromaDB 持久化目录（无需修改）──────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── JWT ─────────────────────────────────────────────────────
# ⚠️ 生产环境务必更换为随机 32 位以上字符串
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── DeepSeek LLM ────────────────────────────────────────────
# [用户填写] 请替换为您的 DeepSeek API Key
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Embedding 模型 ──────────────────────────────────────────
# provider: "siliconflow"（推荐，无需下载模型）| "local"（需下载 bge-large-zh-v1.5）
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# ── SiliconFlow API（EMBEDDING_PROVIDER=siliconflow 时必填）───
# [用户填写] 请替换为您的 SiliconFlow API Key
# 获取地址: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── 文件上传 ────────────────────────────────────────────────
UPLOAD_DIR=./data/files
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,pptx,md,jpg,png,jpeg

# ── RAG 参数（可根据效果调整）─────────────────────────────────
RAG_SIMILARITY_THRESHOLD=0.45
RAG_TOP_K=10
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150

# ── 安全开关 ─────────────────────────────────────────────────
PII_DETECTION_ENABLED=true
PROMPT_INJECTION_DETECTION_ENABLED=true

# ── 管理员初始化 ─────────────────────────────────────────────
# [用户填写] 初始化脚本会使用此账号创建管理员
ADMIN_USERNAME=admin001
ADMIN_PASSWORD=Admin@123

# ── 日志级别 (DEBUG / INFO / WARNING / ERROR) ────────────────
LOG_LEVEL=INFO
