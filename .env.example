# PostgreSQL
DATABASE_URL=postgresql+asyncpg://eduraq:eduraq@localhost:5432/eduraq
DATABASE_URL_SYNC=postgresql://eduraq:eduraq@localhost:5432/eduraq

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# JWT
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# DeepSeek LLM
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# Embedding
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# File Upload
UPLOAD_DIR=./data/files
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,pptx,md,jpg,png,jpeg

# RAG Parameters
RAG_SIMILARITY_THRESHOLD=0.45
RAG_TOP_K=10
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150

# Admin Init
ADMIN_USERNAME=admin001
ADMIN_PASSWORD=Admin@123
